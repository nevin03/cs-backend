# Django Core
SECRET_KEY=django-insecure-dev-secret-key-change-in-production-abc123xyz
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# Database
# USE_SQLITE=True uses SQLite locally (bypasses psycopg2 DLL block)
USE_SQLITE=True
DB_NAME=portfolio_db
DB_USER=postgres
DB_PASSWORD=yourpassword
DB_HOST=localhost
DB_PORT=5432

# CORS
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Media / Storage
USE_S3=False

# AWS S3 (only required if USE_S3=True)
AWS_ACCESS_KEY_ID=your-aws-access-key
AWS_SECRET_ACCESS_KEY=your-aws-secret-key
AWS_STORAGE_BUCKET_NAME=your-bucket-name
AWS_S3_REGION_NAME=ap-south-1
AWS_S3_CUSTOM_DOMAIN=

# Local media (used when USE_S3=False)
MEDIA_URL=/media/
MEDIA_ROOT=media/

# Rate Limiting
CONTACT_RATE_LIMIT=5/m

# Upload Settings (for videos)
DATA_UPLOAD_MAX_MEMORY_SIZE=104857600
FILE_UPLOAD_MAX_MEMORY_SIZE=104857600
